pipeline {

    agent any

    environment {
        IMAGE_NAME = "faceattendance:latest"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Shakirali62050/Smart_campus_attendance_system.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t faceattendance:latest .'
            }
        }

        stage('Load Image into Minikube') {
            steps {
                sh 'minikube image load faceattendance:latest'
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                sh 'kubectl apply -f k8s/'
            }
        }

        stage('Check Deployment') {
            steps {
                sh 'kubectl get pods'
                sh 'kubectl get svc'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful!'
        }

        failure {
            echo 'Deployment Failed!'
        }
    }
}

